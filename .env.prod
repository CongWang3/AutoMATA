# =============================================================================
# AutoMATA 自建部署（拉公开 GHCR 镜像）— 环境变量模板
# 用法：复制本文件为部署目录下的 `.env.prod`，替换所有占位符后再执行 compose。
# 注意：执行 docker compose 时必须加 `--env-file .env.prod`，否则镜像名/MYSQL 变量无法正确解析。
# =============================================================================

# 镜像仓库主机（compose 中变量名沿用 ALIYUN_REGISTRY，自建用户请填 ghcr.io）
# 勿填写阿里云示例地址，除非你确实把镜像同步到了自己的 ACR。
ALIYUN_REGISTRY=ghcr.io

# 镜像标签（须与 GHCR Packages 中存在的 tag 一致，否则 pull 报 manifest unknown）
FRONTEND_IMAGE_TAG=latest
BACKEND_IMAGE_TAG=latest

# 文档用：当前上游 CI 推送命名空间（GitHub Owner 小写）；fork 后请到 Packages 核对路径
GHCR_OWNER=congwang3

# 宿主机映射端口（与防火墙、反向代理 upstream 一致）。若修改，网关 upstream 必须同步。
FRONTEND_HOST_PORT=8080
BACKEND_HOST_PORT=18005
DOWNLOAD_HOST_PORT=18001

# 应用配置（须与 docker-compose.prod.yml 中 APP_ENV 一致）
APP_ENV=production
TZ=Asia/Shanghai
APP_NAME=AutoMATA
APP_VERSION=1.0.0
DEBUG=False
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8005

# 独立下载服务
DOWNLOAD_SERVER_HOST=0.0.0.0
DOWNLOAD_SERVER_PORT=8001
# 主站与 /download、/job-result 同域反代时建议留空（API 返回相对路径）
DOWNLOAD_PUBLIC_BASE_URL=
PYTHON_EXEC_PATH=python
RSCRIPT_PATH=/opt/conda/envs/R_442/bin/Rscript

# 数据库（容器内须使用服务名 mysql）
DB_USER=automata
DB_PASSWORD=replace-with-strong-password
DB_HOST=mysql
DB_PORT=3306
DB_NAME=automata
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password

# 参考注释库（可选）：将 SQL 放入 ./data/reference_sql 后取消下行注释
REFERENCE_DATA_SQL_DIR=/app/reference_sql

# 安全（SECRET_KEY 请用随机长串，例如：openssl rand -hex 32）
SECRET_KEY=replace-with-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件上传
MAX_UPLOAD_SIZE=524288000
UPLOAD_DIR=./uploaded_files
ALLOWED_FILE_TYPES=["txt","csv","tsv","xlsx","xls","pth","pkl"]

# Redis（容器内服务名 redis）
REDIS_URL=redis://redis:6379/0

# CORS：改为你的前端访问来源（含协议与域名），JSON 数组格式
CORS_ORIGINS=[""] #"https://your-domain.com"

# 邮件（按需）
EMAIL_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SSL=false
SMTP_FROM_NAME=AutoMATA

# AI Agent（按需）
# AGENT_BYOK_DIR=/app/data/agent_byok
AGENT_ENABLED=false
AGENT_DEFAULT_PROVIDER=openai
AGENT_OPENAI_API_KEY=
AGENT_OPENAI_BASE_URL=
AGENT_OPENAI_MODEL=gpt-4o
AGENT_QWEN_API_KEY=
AGENT_QWEN_MODEL=qwen-plus
AGENT_DEEPSEEK_API_KEY=
AGENT_DEEPSEEK_MODEL=deepseek-chat
AGENT_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AGENT_MAX_TURNS=10
